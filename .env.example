# PostgreSQL
POSTGRES_USER=mcp_registry
POSTGRES_PASSWORD=mcp_registry_dev_123
POSTGRES_DB=mcp_registry
DATABASE_URL=postgresql+asyncpg://mcp_registry:mcp_registry_dev_123@postgres:5432/mcp_registry

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gateway
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://auth:8000
REGISTRY_SERVICE_URL=http://registry:8001
RUNTIME_SERVICE_URL=http://runtime:8002
AUDIT_SERVICE_URL=http://audit:8003

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Default Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@agenthub.local
